[Unit]
Description=AXIOM FastAPI Backend
After=network.target

[Service]
Type=simple
User=axiom
WorkingDirectory=/opt/axiom/backend
Environment="PATH=/opt/axiom/backend/venv/bin"
EnvironmentFile=/opt/axiom/backend/.env
ExecStart=/opt/axiom/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
